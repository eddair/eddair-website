---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-20 md:py-32">
  <div class="container-eddair">
    <div class="grid md:grid-cols-2 gap-0">
      <div class="aspect-[4/3] md:aspect-auto md:min-h-[400px] bg-[#e0e0e0] flex items-center justify-center">
        <span class="text-[var(--text-gray)] text-sm">Lifestyle Foto</span>
      </div>
      <div class="bg-[var(--bg-beige)] p-12 md:p-16 flex flex-col justify-center">
        <h2 class="text-3xl md:text-4xl font-semibold text-[var(--text-primary)] mb-6">
          {t.accessories.title}
        </h2>
        <a
          href={getLocalizedPath('/products', lang)}
          class="inline-flex items-center justify-center w-fit px-8 py-4 bg-[var(--btn-bg)] text-[var(--btn-text)] text-sm uppercase tracking-[2px] hover:bg-[#333] transition-colors"
          style="border-radius: var(--btn-border-radius);"
        >
          {t.accessories.cta}
        </a>
      </div>
    </div>
  </div>
</section>
