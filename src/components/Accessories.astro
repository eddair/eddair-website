---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="acc-section">
  <div class="acc-box">
    <div class="acc-image">
      <div class="acc-image-placeholder">Bild</div>
    </div>
    <div class="acc-content">
      <h2 class="acc-title">{t.accessories.title}</h2>
      <a href={getLocalizedPath('/products', lang)} class="acc-btn">{t.accessories.cta}</a>
    </div>
  </div>
</section>

<style>
  .acc-section {
    width: 100%;
    background: #f4f4f4;
    padding: 30px 0;
  }

  .acc-box {
    max-width: 1100px;
    margin: 0 auto;
    background: #bcac9b;
    border-radius: 10px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .acc-image {
    min-height: 300px;
    background: #a89888;
  }

  .acc-image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
  }

  .acc-content {
    padding: 60px 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .acc-title {
    font-size: 28px;
    font-weight: 300;
    color: #0a0a0a;
    margin: 0 0 24px 0;
  }

  .acc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    background: #0a0a0a;
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    border-radius: 0;
    width: fit-content;
  }

  .acc-btn:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .acc-box {
      grid-template-columns: 1fr;
    }
    .acc-content {
      padding: 40px 30px;
    }
  }
</style>
