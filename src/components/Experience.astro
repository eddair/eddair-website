---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="exp-section">
  <div class="exp-box">
    <div class="exp-content">
      <h2 class="exp-title">{t.experience.title}</h2>
      <a href={getLocalizedPath('/demo', lang)} class="exp-btn">{t.experience.ctaDemo}</a>
    </div>
    <div class="exp-image">
      <div class="exp-image-placeholder">Showroom Foto</div>
    </div>
  </div>
</section>

<style>
  .exp-section {
    width: 100%;
    background: #EBEBEB;
    padding: 16px 0;
  }

  .exp-box {
    max-width: 1100px;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 0;
    border: 1px solid #e0e0e0;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .exp-content {
    padding: 60px 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .exp-title {
    font-size: 28px;
    font-weight: 300;
    color: #000000;
    margin: 0 0 24px 0;
  }

  .exp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    background: #000000;
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    border-radius: 0;
    width: fit-content;
  }

  .exp-btn:hover {
    opacity: 0.9;
  }

  .exp-image {
    min-height: 300px;
  }

  .exp-image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 300px;
    background: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6B6B6B;
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .exp-box {
      grid-template-columns: 1fr;
    }
    .exp-content {
      padding: 40px 30px;
    }
  }
</style>
