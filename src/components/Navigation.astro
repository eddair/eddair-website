---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = [
  { href: getLocalizedPath('/eddy-wall-box', lang), label: t.nav.products.eddyWallBox },
  { href: getLocalizedPath('/eddy-mobile', lang), label: t.nav.products.eddyMobile },
  { href: getLocalizedPath('/eddy-window', lang), label: t.nav.products.eddyWindow },
  { href: getLocalizedPath('/eddy-outdoor', lang), label: t.nav.products.eddyOutdoor },
  { href: getLocalizedPath('/referenzen', lang), label: t.nav.references },
  { href: getLocalizedPath('/ueber-uns', lang), label: t.nav.about },
];
---

<header
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-[1000] h-[60px] transition-all duration-300"
  data-scrolled="false"
>
  <nav class="container-eddair h-full flex items-center justify-between">
    <a href={getLocalizedPath('/', lang)} class="text-lg font-medium uppercase tracking-[8px] text-inherit transition-colors hover:opacity-80">
      EDDAIR
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm uppercase tracking-wider text-inherit transition-colors hover:opacity-80"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right: Language Flags + Search + Contact -->
    <div class="hidden lg:flex items-center gap-6">
      <LanguageSwitcher slot="desktop" />
      <button type="button" aria-label={t.nav.search} class="text-inherit hover:opacity-80 transition-opacity">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      <a href={getLocalizedPath('/kontakt', lang)} class="text-inherit hover:opacity-80 transition-opacity" aria-label={t.nav.contact}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </a>
    </div>

    <!-- Mobile: Flags + Hamburger -->
    <div class="lg:hidden flex items-center gap-4">
      <LanguageSwitcher slot="mobile" />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label={t.nav.menuOpen}
        class="p-2 text-inherit"
      >
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden absolute top-[60px] left-0 right-0 bg-white text-black shadow-lg hidden">
    <ul class="py-6 px-6 space-y-4">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block text-sm uppercase tracking-wider py-2 hover:opacity-80">
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-4 border-t">
        <a href={getLocalizedPath('/kontakt', lang)} class="block text-sm uppercase tracking-wider py-2 hover:opacity-80">
          {t.nav.contact}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('main-nav');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  function updateNavStyle() {
    const isHome = window.location.pathname === '/' || window.location.pathname === '/en/' || window.location.pathname === '/en';
    const scrolled = window.scrollY > 50;
    const useLight = !isHome || scrolled;
    header?.setAttribute('data-scrolled', String(useLight));
    if (useLight) {
      header?.classList.remove('bg-transparent', 'text-white');
      header?.classList.add('bg-white', 'text-black', 'shadow-sm');
    } else {
      header?.classList.remove('bg-white', 'text-black', 'shadow-sm');
      header?.classList.add('bg-transparent', 'text-white');
    }
  }

  function toggleMobileMenu() {
    mobileMenu?.classList.toggle('hidden');
    const isOpen = !mobileMenu?.classList.contains('hidden');
    menuIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  }

  window.addEventListener('scroll', updateNavStyle);
  updateNavStyle();
  mobileBtn?.addEventListener('click', toggleMobileMenu);

  document.querySelectorAll('#mobile-menu a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
