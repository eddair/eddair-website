---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-24 md:py-32 animate-on-scroll">
  <div class="container-eddair text-center">
    <h2 class="text-3xl md:text-4xl font-semibold text-[var(--text-primary)]">
      {t.productsIntro.title}
    </h2>
  </div>
</section>
