---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="mission-section">
  <div class="mission-inner">
    <h2 class="mission-title">{t.mission.title}</h2>
    <p class="mission-text">{t.mission.text}</p>
    <a href={getLocalizedPath('/ueber-uns', lang)} class="mission-link">{t.mission.cta}</a>
  </div>
</section>

<style>
  .mission-section {
    width: 100%;
    background: #f4f4f4;
    padding: 60px 40px;
    margin: 0;
    border-radius: 0;
  }

  .mission-inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .mission-title {
    font-size: 28px;
    font-weight: 300;
    color: #0a0a0a;
    margin: 0 0 16px 0;
  }

  .mission-text {
    font-size: 16px;
    color: #696969;
    line-height: 1.6;
    margin: 0 0 24px 0;
  }

  .mission-link {
    font-size: 14px;
    color: #0a0a0a;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 500;
  }

  .mission-link:hover {
    opacity: 0.7;
  }
</style>
