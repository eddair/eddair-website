---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="cta-section">
  <div class="cta-box">
    <h2 class="cta-title">{t.b2b.title}</h2>
    <a href={getLocalizedPath('/kontakt', lang)} class="cta-btn">{t.b2b.cta}</a>
  </div>
</section>

<style>
  .cta-section {
    width: 100%;
    background: #EBEBEB;
    padding: 16px 0;
  }

  .cta-box {
    max-width: 1100px;
    margin: 0 auto;
    background: #000000;
    border-radius: 10px;
    padding: 60px;
    text-align: center;
  }

  .cta-title {
    font-size: 28px;
    font-weight: 300;
    color: #ffffff;
    margin: 0 0 24px 0;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    border: 1px solid #ffffff;
    background: transparent;
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    border-radius: 0;
  }

  .cta-btn:hover {
    background: #ffffff;
    color: #000000;
  }
</style>
