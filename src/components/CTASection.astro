---
interface Props {
  headline: string;
  ctaText: string;
  ctaHref: string;
}

const { headline, ctaText, ctaHref } = Astro.props;
---

<section class="py-24 px-6 lg:px-12 text-center animate-on-scroll">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-8">{headline}</h2>
    <a
      href={ctaHref}
      class="inline-block px-10 py-4 bg-[#00d4ff] text-black font-medium uppercase tracking-wider hover:bg-white transition-colors"
    >
      {ctaText}
    </a>
  </div>
</section>
