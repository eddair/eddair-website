---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stories = [
  { name: 'Westpark', location: 'Ingolstadt', href: getLocalizedPath('/referenzen/westpark', lang), image: '/images/referenzen/westpark.jpg' },
  { name: 'Projekt 2', location: 'Stadt', href: getLocalizedPath('/referenzen/projekt-2', lang), image: '' },
  { name: 'Projekt 3', location: 'Stadt', href: getLocalizedPath('/referenzen/projekt-3', lang), image: '' },
  { name: 'Projekt 4', location: 'Stadt', href: getLocalizedPath('/referenzen/projekt-4', lang), image: '' },
];
---

<section class="py-20 md:py-32 bg-white animate-on-scroll">
  <div class="container-eddair">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-12">
      <h2 class="text-3xl md:text-4xl font-semibold text-[var(--text-primary)]">
        {t.stories.title}
      </h2>
      <a
        href={getLocalizedPath('/referenzen', lang)}
        class="text-sm uppercase tracking-wider text-[var(--text-primary)] hover:underline w-fit"
      >
        {t.stories.cta}
      </a>
    </div>

    <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory pb-4 scrollbar-hide" style="scrollbar-width: none; -ms-overflow-style: none;">
      {stories.map((story) => (
        <a
          href={story.href}
          class="flex-shrink-0 w-[350px] snap-start group"
        >
          <div class="relative aspect-[3/4] overflow-hidden">
            <div class="absolute inset-0 bg-[#e0e0e0] flex items-center justify-center">
              <span class="text-[var(--text-gray)] text-sm">{story.name}</span>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent" />
            <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
              <p class="font-semibold text-lg">{story.name}</p>
              <p class="text-sm opacity-90">{story.location}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
