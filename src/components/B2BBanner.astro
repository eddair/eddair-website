---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-20 md:py-24 bg-[var(--bg-black)] text-white animate-on-scroll">
  <div class="container-eddair text-center">
    <h2 class="text-3xl md:text-4xl font-semibold mb-8">
      {t.b2b.title}
    </h2>
    <a
      href={getLocalizedPath('/kontakt', lang)}
      class="inline-flex items-center justify-center w-fit px-8 py-4 bg-white text-[var(--text-primary)] text-sm uppercase tracking-[2px] hover:bg-gray-200 transition-colors"
      style="border-radius: var(--btn-border-radius);"
    >
      {t.b2b.cta}
    </a>
  </div>
</section>
