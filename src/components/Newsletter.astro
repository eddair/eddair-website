---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="nl-section">
  <div class="nl-card">
    <div class="nl-left">
      <h2 class="nl-title">{t.newsletter.title}</h2>
      <p class="nl-text">{t.newsletter.text}</p>
    </div>
    <div class="nl-right">
      <input class="nl-input" type="email" placeholder={t.newsletter.placeholder} />
      <button class="nl-btn">{t.newsletter.cta}</button>
      <small class="nl-small">{t.newsletter.privacy}</small>
    </div>
  </div>
</section>

<style>
  .nl-section {
    width: 100%;
    min-width: 100%;
    max-width: none;
    background: #0a0a0a !important;
    padding: 80px 40px;
    margin: 0;
    box-sizing: border-box;
  }

  .nl-card {
    max-width: 800px;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 8px;
    padding: 48px 56px;
    display: grid;
    grid-template-columns: 55% 45%;
    gap: 40px;
    align-items: center;
  }

  .nl-title {
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #0a0a0a;
    margin: 0 0 8px 0;
  }

  .nl-text {
    font-size: 13px;
    color: #696969;
    margin: 0;
    line-height: 1.5;
  }

  .nl-right {
    display: flex;
    flex-direction: column;
  }

  .nl-input {
    width: 100%;
    height: 44px;
    padding: 0 16px;
    border: 1px solid #ccc;
    border-radius: 0;
    font-size: 13px;
    box-sizing: border-box;
    outline: none;
    margin-bottom: 10px;
  }

  .nl-btn {
    width: 100%;
    height: 44px;
    padding: 0;
    background: #0a0a0a;
    color: #ffffff;
    border: none;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    border-radius: 0;
  }

  .nl-btn:hover {
    opacity: 0.9;
  }

  .nl-small {
    font-size: 11px;
    color: #696969;
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .nl-card {
      grid-template-columns: 1fr;
      padding: 24px;
      gap: 24px;
    }
  }
</style>
