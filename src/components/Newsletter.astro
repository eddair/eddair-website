<section class="nl-outer">
  <div class="nl-card">
    <div class="nl-left">
      <p class="nl-label">BLEIBEN SIE INFORMIERT</p>
      <p class="nl-sub">Neuigkeiten, Updates und Referenzen: Hier erfahren Sie es zuerst.</p>
    </div>
    <div class="nl-right">
      <input type="email" class="nl-input" placeholder="E-Mail*" />
      <button class="nl-btn">ABONNIEREN</button>
      <span class="nl-disclaimer">EDDAIR wird Ihre Daten nur für die angegebenen Zwecke verwenden.</span>
    </div>
  </div>
</section>

<style>
.nl-outer {
  width: 100vw;
  max-width: none;
  margin-left: calc(50% - 50vw);
  margin-right: calc(50% - 50vw);
  padding: 60px 80px;
  background: #000000;
  box-sizing: border-box;
}

.nl-card {
  max-width: 836px;
  width: 100%;
  margin: 0 auto;
  background: #ffffff;
  border-radius: 0;
  padding: 40px 48px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
  align-items: center;
  box-sizing: border-box;
}

.nl-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #000000;
  margin: 0 0 12px 0;
}

.nl-sub {
  font-size: 14px;
  color: #6B6B6B;
  margin: 0;
  line-height: 1.5;
}

.nl-right {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.nl-input {
  width: 100%;
  height: 44px;
  border: 1px solid #D0D0D0;
  padding: 0 16px;
  font-size: 14px;
  box-sizing: border-box;
  background: #fff;
  outline: none;
  font-family: inherit;
}

.nl-btn {
  width: 100%;
  height: 44px;
  background: #000000;
  color: #ffffff;
  border: none;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  font-family: inherit;
}

.nl-disclaimer {
  font-size: 11px;
  color: #999999;
  line-height: 1.4;
}
</style>
