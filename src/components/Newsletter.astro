---
const { lang = 'de' } = Astro.props;
---

<section class="newsletter-section">
  <div class="newsletter-card">
    <div class="newsletter-left">
      <h3>BLEIBEN SIE INFORMIERT</h3>
      <p>Neuigkeiten, Updates und Referenzen: Hier erfahren Sie es zuerst.</p>
    </div>
    <div class="newsletter-right">
      <input type="email" placeholder="E-Mail*" />
      <button>ABONNIEREN</button>
      <span>EDDAIR wird Ihre Daten nur für die angegebenen Zwecke verwenden.</span>
    </div>
  </div>
</section>

<style>
/* FULLSCREEN SEKTION - MUSS VON RAND ZU RAND GEHEN */
.newsletter-section {
  width: 100% !important;
  max-width: none !important;
  margin: 0 !important;
  padding: 80px 40px !important;
  background: #0a0a0a !important;
  box-sizing: border-box !important;
}

/* WEISSE KARTE ZENTRIERT */
.newsletter-card {
  max-width: 760px !important;
  margin: 0 auto !important;
  background: #ffffff !important;
  border-radius: 4px !important;
  padding: 48px 56px !important;
  display: grid !important;
  grid-template-columns: 55% 45% !important;
  gap: 40px !important;
  align-items: center !important;
}

/* LINKE SEITE */
.newsletter-left h3 {
  font-size: 16px !important;
  font-weight: 700 !important;
  letter-spacing: 2px !important;
  text-transform: uppercase !important;
  margin: 0 0 12px 0 !important;
  color: #0a0a0a !important;
}

.newsletter-left p {
  font-size: 13px !important;
  color: #696969 !important;
  margin: 0 !important;
  line-height: 1.5 !important;
}

/* RECHTE SEITE */
.newsletter-right {
  display: flex !important;
  flex-direction: column !important;
  gap: 10px !important;
}

.newsletter-right input {
  width: 100% !important;
  height: 44px !important;
  border: 1px solid #cccccc !important;
  padding: 0 16px !important;
  font-size: 14px !important;
  box-sizing: border-box !important;
  outline: none !important;
  background: #fff !important;
}

.newsletter-right button {
  width: 100% !important;
  height: 44px !important;
  background: #0a0a0a !important;
  color: #ffffff !important;
  border: none !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  letter-spacing: 2px !important;
  text-transform: uppercase !important;
  cursor: pointer !important;
}

.newsletter-right span {
  font-size: 11px !important;
  color: #696969 !important;
  line-height: 1.4 !important;
}
</style>
