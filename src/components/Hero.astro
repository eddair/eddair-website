---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true" />
  <div class="hero__content">
    <div class="hero__text">
      <h1 class="hero__h1">
        <span class="hero__h1-normal">{t.hero.title1}</span>
        <span class="hero__h1-bold">{t.hero.title2}</span>
      </h1>
    </div>
    <a href={getLocalizedPath('/products', lang)} class="hero__cta">{t.hero.cta}</a>
  </div>
</section>

<style>
  .hero {
    width: 100vw;
    min-height: 100dvh;
    height: 100dvh;
    position: relative;
    overflow: hidden;
    margin: 0;
    padding: 0;
    border-radius: 0;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-color: #000000;
    background-image: url('/images/newsletter-bg.jpg');
    background-size: cover;
    background-position: center;
  }

  .hero__content {
    position: relative;
    z-index: 10;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 40px 80px 40px;
  }

  .hero__text {
    margin-bottom: 24px;
  }

  .hero__h1 {
    font-size: 52px !important;
    font-weight: 700 !important;
    line-height: 1.1 !important;
    color: #ffffff !important;
    margin: 0;
  }

  .hero__h1-normal {
    font-weight: 400 !important;
    display: block;
  }

  .hero__h1-bold {
    font-weight: 700 !important;
    display: block;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background: #000000;
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    border-radius: 0;
    width: fit-content;
  }

  .hero__cta:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .hero__h1 {
      font-size: 32px !important;
    }
  }
</style>
