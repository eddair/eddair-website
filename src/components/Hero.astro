---
interface Props {
  headline: string;
  subline: string;
  ctaText: string;
  ctaHref: string;
}

const { headline, subline, ctaText, ctaHref } = Astro.props;
---

<section class="min-h-screen flex flex-col justify-end pb-20 px-6 lg:px-12 relative overflow-hidden">
  <!-- Background gradient placeholder -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-black via-gray-900/50 to-black"
    aria-hidden="true"
  />
  <div class="relative z-10 max-w-4xl">
    <p class="text-[#00d4ff] text-sm uppercase tracking-[0.2em] mb-4">{subline}</p>
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight mb-8">{headline}</h1>
    <a
      href={ctaHref}
      class="inline-block px-8 py-4 bg-white text-black font-medium uppercase tracking-wider hover:bg-[#00d4ff] hover:text-black transition-colors"
    >
      {ctaText}
    </a>
  </div>
</section>
