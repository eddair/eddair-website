---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const products = [
  { slug: 'eddy-wall-box', name: 'eddy-wall-box', href: getLocalizedPath('/eddy-wall-box', lang) },
  { slug: 'eddy-mobile-doublesided', name: 'eddy-mobile doublesided', href: getLocalizedPath('/eddy-mobile-doublesided', lang) },
  { slug: 'eddy-mobile-onesided', name: 'eddy-mobile onesided', href: getLocalizedPath('/eddy-mobile-onesided', lang) },
  { slug: 'eddy-window', name: 'eddy-window', href: getLocalizedPath('/eddy-window', lang) },
  { slug: 'eddy-outdoor', name: 'eddy-outdoor', href: getLocalizedPath('/eddy-outdoor', lang) },
];
---

<section class="py-12 md:py-20 overflow-hidden">
  <div class="flex gap-5 overflow-x-auto snap-x snap-mandatory pb-4 px-4 md:px-6 scrollbar-hide" style="scrollbar-width: none; -ms-overflow-style: none;">
    {products.map((product) => (
      <a
        href={product.href}
        class="flex-shrink-0 w-[280px] md:w-[300px] snap-start group"
      >
        <div class="bg-white p-6 flex flex-col h-[400px] border border-[#e0e0e0] hover:border-[var(--text-gray)] transition-colors">
          <div class="flex-1 flex items-center justify-center bg-[#e0e0e0] text-[var(--text-gray)] text-center px-4">
            <span class="text-sm font-medium">{product.name}</span>
          </div>
          <p class="mt-4 text-base text-[var(--text-primary)]">{product.name}</p>
          <span class="mt-auto text-sm uppercase tracking-wider text-[var(--text-primary)] group-hover:underline">
            {t.productSlider.learnMore}
          </span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
