---
const features = [
  '4K Ultra HD Displays',
  '24/7 Betrieb, industrietauglich',
  'Cloud-basiertes Content Management',
  'Plug & Play Installation',
  'Remote Monitoring & Updates',
];
---

<section class="py-24 px-6 lg:px-12 bg-white/5 animate-on-scroll">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center">Technologie & Features</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="flex items-start gap-4">
          <span class="text-[#00d4ff] text-2xl" aria-hidden="true">✓</span>
          <p class="text-lg text-white/90">{feature}</p>
        </div>
      ))}
    </div>
  </div>
</section>
