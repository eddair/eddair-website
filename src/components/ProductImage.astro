<section class="pi-section">
  <div class="pi-box">
    <div class="pi-image">
      <img src="/images/newsletter-bg.jpg" alt="EDDAIR Produkt" class="pi-img" />
    </div>
  </div>
</section>

<style>
  .pi-section {
    width: 100%;
    background: #f4f4f4;
    padding: 12px 0;
  }

  .pi-box {
    max-width: 1100px;
    margin: 0 auto;
    background: #111111;
    border-radius: 10px;
    overflow: hidden;
    min-height: 400px;
  }

  .pi-image {
    width: 100%;
    min-height: 400px;
  }

  .pi-img {
    width: 100%;
    height: 100%;
    min-height: 400px;
    object-fit: cover;
    display: block;
  }
</style>
