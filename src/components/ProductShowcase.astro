---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const products = [
  { name: 'EDDY-WALL-BOX', href: getLocalizedPath('/eddy-wall-box', lang) },
  { name: 'EDDY-MOBILE', href: getLocalizedPath('/eddy-mobile', lang) },
  { name: 'EDDY-WINDOW', href: getLocalizedPath('/eddy-window', lang) },
  { name: 'EDDY-OUTDOOR', href: getLocalizedPath('/eddy-outdoor', lang) },
  { name: '5. Produkt', href: getLocalizedPath('/products', lang) },
];
---

<section class="ps-section">
  <div class="ps-box">
    <h2 class="ps-title">{t.productSlider.title}</h2>
    <div class="ps-grid">
      {products.map((p) => (
        <a href={p.href} class="ps-card">
          <span class="ps-card-name">{p.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ps-section {
    width: 100%;
    background: #EBEBEB;
    padding: 16px 0;
  }

  .ps-box {
    max-width: 1100px;
    margin: 0 auto;
    background: #1a1a1a;
    border-radius: 10px;
    padding: 30px;
  }

  .ps-title {
    font-size: 28px;
    font-weight: 300;
    color: #ffffff;
    margin: 0 0 24px 0;
  }

  .ps-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
  }

  .ps-card {
    background: #2c2c2c;
    border-radius: 6px;
    padding: 16px;
    text-decoration: none;
    color: #ffffff;
    transition: opacity 0.2s;
  }

  .ps-card:hover {
    opacity: 0.9;
  }

  .ps-card-name {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {
    .ps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
