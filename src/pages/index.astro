---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import ProductsIntro from '../components/ProductsIntro.astro';
import ProductSlider from '../components/ProductSlider.astro';
import Mission from '../components/Mission.astro';
import AppSection from '../components/AppSection.astro';
import Accessories from '../components/Accessories.astro';
import Stories from '../components/Stories.astro';
import Experience from '../components/Experience.astro';
import Sustainability from '../components/Sustainability.astro';
import B2BBanner from '../components/B2BBanner.astro';
import TrustBar from '../components/TrustBar.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t.meta.title} description={t.meta.description}>
  <Navigation />
  <main>
    <Hero />
    <ProductsIntro />
    <ProductSlider />
    <Mission />
    <AppSection />
    <Accessories />
    <Stories />
    <Experience />
    <Sustainability />
    <B2BBanner />
    <TrustBar />
    <Newsletter />
    <Footer />
  </main>
</Layout>
