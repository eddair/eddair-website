---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const products = [
  { name: 'eddy-wall-box', href: getLocalizedPath('/eddy-wall-box', lang) },
  { name: 'eddy-mobile doublesided', href: getLocalizedPath('/eddy-mobile-doublesided', lang) },
  { name: 'eddy-mobile onesided', href: getLocalizedPath('/eddy-mobile-onesided', lang) },
  { name: 'eddy-window', href: getLocalizedPath('/eddy-window', lang) },
  { name: 'eddy-outdoor', href: getLocalizedPath('/eddy-outdoor', lang) },
];
---

<Layout title={t.productsPage.title} description={t.productsPage.metaDescription}>
  <Navigation />
  <main class="min-h-screen py-20">
    <div class="container-eddair">
      <h1 class="text-3xl md:text-4xl font-semibold mb-12">{t.productsPage.title}</h1>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((p) => (
          <a href={p.href} class="block p-6 bg-white border border-[#e0e0e0] hover:border-[var(--text-gray)] transition-colors">
            <div class="aspect-[4/3] bg-[#e0e0e0] flex items-center justify-center mb-4">
              <span class="text-[var(--text-gray)] text-sm">{p.name}</span>
            </div>
            <h2 class="text-lg font-semibold">{p.name}</h2>
            <span class="text-sm uppercase tracking-wider mt-2 inline-block">{t.productsPage.discover} &gt;</span>
          </a>
        ))}
      </div>
    </div>
    <Footer />
  </main>
</Layout>
