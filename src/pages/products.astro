---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const products = [
  {
    id: 'pro',
    name: 'EDDAIR Pro Display',
    description: 'Professionelle Digital Signage Lösung für Einzelhandel, Hotels und Unternehmen. 4K Ultra HD, 24/7 Betrieb, industrietauglich.',
    specs: ['4K Ultra HD', '55" - 86"', '24/7 Betrieb', 'Cloud CMS', 'Plug & Play'],
  },
  {
    id: 'touch',
    name: 'EDDAIR Touch',
    description: 'Interaktiver Touchscreen für Showrooms, Empfangsbereiche und Events. Multi-Touch, gestenunterstützt, hochwertige Verarbeitung.',
    specs: ['Multi-Touch', '32" - 65"', '4K Auflösung', 'Stahlrahmen', 'Kiosk-Modus'],
  },
  {
    id: 'wall',
    name: 'EDDAIR Wall',
    description: 'Videowall-System für große Flächen. Nahtlose Bildübergänge, skalierbar, ideal für immersive Erlebnisse.',
    specs: ['Nahtlos', 'Skalierbar', '4K pro Panel', 'Synchrones Playback', 'Remote-Steuerung'],
  },
];
---

<BaseLayout
  title="Produkte | Digital Signage Displays"
  description="EDDAIR Produktübersicht: Pro Display, Touch und Wall — Premium Digital Signage Lösungen für Unternehmen."
>
  <Header />
  <main>
    {products.map((product) => (
      <section
        id={product.id}
        class="min-h-screen flex flex-col justify-center py-24 px-6 lg:px-12 animate-on-scroll"
      >
        <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
          <div class="aspect-video bg-gradient-to-b from-gray-800 to-gray-900 flex items-center justify-center">
            <span class="text-white/30 text-sm uppercase tracking-wider">Bild-Platzhalter</span>
          </div>
          <div>
            <h2 class="text-3xl md:text-4xl font-bold mb-6">{product.name}</h2>
            <p class="text-white/80 text-lg mb-8">{product.description}</p>
            <ul class="space-y-2">
              {product.specs.map((spec) => (
                <li class="flex items-center gap-2">
                  <span class="text-[#00d4ff]">✓</span>
                  <span>{spec}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    ))}
  </main>
  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1 }
    );

    document.querySelectorAll('.animate-on-scroll').forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
