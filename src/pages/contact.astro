---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Kontakt"
  description="Kontaktieren Sie EDDAIR für Premium Digital Signage Lösungen. Sales: sales@eddair.com"
>
  <Header />
  <main class="min-h-screen pt-32 pb-24 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-16">Kontakt</h1>
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div>
          <h2 class="text-2xl font-semibold mb-6">Schreiben Sie uns</h2>
          <p class="text-white/80 mb-8">
            Haben Sie Fragen zu unseren Produkten oder möchten Sie ein individuelles Angebot? Wir freuen uns auf Ihre Nachricht.
          </p>
          <ContactForm />
        </div>
        <div class="lg:pl-8">
          <h2 class="text-2xl font-semibold mb-6">Kontaktinformationen</h2>
          <p class="text-white/80 mb-4">E-Mail</p>
          <a href="mailto:sales@eddair.com" class="text-[#00d4ff] hover:underline text-lg">
            sales@eddair.com
          </a>
          <p class="text-white/80 mt-8 mb-4">Mo. – Fr., 9:00 – 18:00 Uhr</p>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
