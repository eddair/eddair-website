---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image = '/images/og-default.jpg' } = Astro.props;
const canonicalUrl = `https://eddair.com${Astro.url.pathname}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "EDDAIR",
  "url": "https://eddair.com",
  "logo": "https://eddair.com/images/logo.png",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "sales@eddair.com",
    "contactType": "sales"
  }
};
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | EDDAIR</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`https://eddair.com${image}`} />
    <meta property="og:locale" content="de_DE" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body class="bg-black text-white font-sans antialiased">
    <slot />
  </body>
</html>
